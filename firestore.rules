rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email != null && (
          request.auth.token.email == "qoziboyevaslbek359@gmail.com" ||
          request.auth.token.email == "admin@tezchipta.uz"
        )) ||
        (hasUserDoc() && userDoc().data.role == 'admin')
      );
    }

    function isDriver() {
      return isAuthenticated() && (
        hasUserDoc() && userDoc().data.role == 'driver'
      );
    }

    // ===============================================================
    // Rules per Collection
    // ===============================================================

    // --- USERS ---
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isDriver());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // --- RIDES ---
    match /rides/{rideId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- DRIVERS ---
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- BOOKINGS ---
    match /bookings/{bookingId} {
      // CREATE
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      // READ (Includes GET and LIST)
      allow read: if isAuthenticated() && resource != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        isDriver()
      );

      // UPDATE
      allow update: if isAuthenticated() && resource != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      // DELETE
      allow delete: if isAdmin();
    }

    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if true; 
      allow create: if isAuthenticated() && (
        request.resource.data.status == null || 
        request.resource.data.status == 'pending'
      );
      allow update, delete: if isAdmin();
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow read: if isAuthenticated() && resource != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (
          (exists(/databases/$(database)/documents/chats/$(chatId)) && 
           get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid) || 
          isAdmin()
        );
      }
    }

    // --- FAQS ---
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- BLOGS ---
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if isAdmin() || isDriver();
      allow update, delete: if isAdmin() || (isDriver() && resource.data.authorId == request.auth.uid);
    }

    // --- SETTINGS ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- MESSAGES (Contact Form) ---
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- NEWSLETTER / SUBSCRIBERS ---
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);
    }
    
    match /subscribers/{subId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);
    }

    match /newsletters/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /user_notifications/{userNotifId} {
      allow read: if isAuthenticated() && resource != null && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource != null && resource.data.userId == request.auth.uid);
    }

    // --- GLOBAL FALLBACK ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

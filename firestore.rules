rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper for server-side updates (Stripe, etc.)
    function isServer() {
      return request.resource.data._serverSecret == "ai_studio_server_secret_2024";
    }

    match /{document=**} {
      // Allow public read for Home page and guest access
      allow read: if true;

      // Allow write if authenticated (Google/Supabase) or if it's the server
      allow write: if request.auth != null || isServer();
    }
  }
}
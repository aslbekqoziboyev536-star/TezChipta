rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.get('email', '').lower() == "qoziboyevaslbek359@gmail.com") ||
        (request.auth.token.get('email', '').lower() == "admin@tezchipta.uz") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isDriver() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'driver'
      );
    }

    function isServer() {
      return request.resource.data != null && 
             '_serverSecret' in request.resource.data && 
             request.resource.data._serverSecret == "ai_studio_server_secret_2024";
    }
    
    function isExistingServer() {
      return resource.data != null && 
             '_serverSecret' in resource.data && 
             resource.data._serverSecret == "ai_studio_server_secret_2024";
    }

    // ===============================================================
    // Rules per Collection
    // ===============================================================

    // --- USERS ---
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin() || isDriver()); // Driver can check passenger info
      allow create: if isServer() || (isAuthenticated() && isOwner(userId));
      allow update: if isServer() || (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    // --- RIDES ---
    match /rides/{rideId} {
      allow read: if true;
      allow create, delete: if isServer() || isAdmin();
      allow update: if isServer() || isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
    }

    // --- DRIVERS ---
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isServer() || isAdmin();
    }

    // --- BOOKINGS ---
    match /bookings/{bookingId} {
      allow list: if isAdmin() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isDriver() // Simplified: drivers can list bookings to find theirs, or better: filtering by rideId
      ));
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        isDriver() // For QR scanning
      );
      allow create: if isServer() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isServer() || isAdmin();
    }

    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isServer() || (isAuthenticated() && request.resource.data.status == 'pending');
      allow update: if isServer() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow list: if isAdmin();
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isServer() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isServer() || isAdmin();

      match /messages/{messageId} {
        allow read, write: if isServer() || isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid);
      }
    }

    // --- FAQS ---
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isServer() || isAdmin();
    }

    // --- BLOGS ---
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if isServer() || isAdmin() || isDriver();
      allow update, delete: if isServer() || isAdmin() || (isDriver() && resource.data.authorId == request.auth.uid);
    }

    // --- SETTINGS ---
    match /settings/{settingId} {
      allow read: if (settingId == 'payment' || settingId == 'public') || isAdmin();
      allow write: if isAdmin();
    }

    // --- MESSAGES (Contact Form) ---
    match /messages/{messageId} {
      allow create: if true; // Public can send messages
      allow read, update, delete: if isServer() || isAdmin();
    }

    // --- NEWSLETTER / SUBSCRIBERS ---
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isServer() || isAdmin();
      allow update, delete: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    match /subscribers/{subId} {
      allow create: if true;
      allow read: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isServer() || isAdmin();
      allow update, delete: if isServer() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /newsletters/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isServer() || isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isServer() || isAdmin();
    }

    match /user_notifications/{userNotifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update: if isServer() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow delete: if isServer() || isAdmin();
    }

    // --- GLOBAL FALLBACK ---
    match /{document=**} {
      allow read, write: if isAdmin() || isServer();
    }
  }
}

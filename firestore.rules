rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function email() {
      return request.auth.token.email;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }

    function userExists() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(uid()));
    }

    function role() {
      return userExists() ? userDoc().data.role : "guest";
    }

    function isAdmin() {
      return isAuth() && (
        email() == "qoziboyevaslbek359@gmail.com" ||
        email() == "admin@tezchipta.uz" ||
        role() == "admin"
      );
    }

    function isDriver() {
      return isAuth() && role() == "driver";
    }

    function isUser() {
      return isAuth() && role() == "user";
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {

      allow create: if isAuth() && uid() == userId;

      allow read: if isAuth() && (
        uid() == userId ||
        isAdmin() ||
        isDriver()
      );

      allow update: if isAuth() && (
        isAdmin() ||
        uid() == userId
      );

      allow delete: if isAdmin();
    }

    // =========================
    // RIDES (public read, admin write)
    // =========================
    match /rides/{rideId} {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =========================
    // DRIVERS
    // =========================
    match /drivers/{driverId} {

      allow read: if true;

      allow write: if isAdmin();
    }

    // =========================
    // FAQS
    // =========================
    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================
    // BOOKINGS (CRITICAL)
    // =========================
    match /bookings/{bookingId} {

      allow create: if isAuth()
        && request.resource.data.userId == uid();

      allow read: if isAuth() && (
        resource.data.userId == uid() ||
        isAdmin() ||
        isDriver()
      );

      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.userId == uid()
      );

      allow delete: if isAdmin();
    }

    // =========================
    // REVIEWS
    // =========================
    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.userId == uid();

      allow update, delete: if isAdmin();
    }

    // =========================
    // CHATS
    // =========================
    match /chats/{chatId} {

      allow read, create, update: if isAuth()
        && resource.data.userId == uid();

      allow delete: if isAdmin();

      match /messages/{messageId} {

        allow read, write: if isAuth();
      }
    }

    // =========================
    // SETTINGS
    // =========================
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================
    // NOTIFICATIONS
    // =========================
    match /notifications/{id} {

      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.userId == uid()
      );

      allow write: if isAdmin();
    }

    match /user_notifications/{id} {

      allow read: if isAuth() &&
        resource.data.userId == uid();

      allow create: if isAuth()
        && request.resource.data.userId == uid();

      allow update, delete: if isAuth()
        && resource.data.userId == uid();
    }

    // =========================
    // BLOGS
    // =========================
    match /blogs/{id} {

      allow read: if true;

      allow create: if isAuth() && (
        isAdmin() || isDriver()
      );

      allow update: if isAuth() && (
        isAdmin() ||
        (isDriver() && resource.data.authorId == uid())
      );

      allow delete: if isAdmin();
    }

    // =========================
    // NEWSLETTER
    // =========================
    match /newsletter_subscribers/{id} {

      allow create: if true;

      allow read: if isAuth() &&
        resource.data.userId == uid();

      allow update, delete: if isAuth() &&
        resource.data.userId == uid() ||
        isAdmin();
    }

    match /subscribers/{id} {

      allow create: if true;

      allow read: if isAuth() &&
        resource.data.userId == uid() ||
        isAdmin();

      allow update, delete: if isAdmin();
    }

    // =========================
    // DEFAULT DENY (IMPORTANT)
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}